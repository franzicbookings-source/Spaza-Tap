rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAuthenticated() && (request.auth.uid == userId || resource.data.email == request.auth.token.email);
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /shops/{shopId} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid; 
      allow read: if isAuthenticated(); // restricted to authenticated users
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /customers/{customerId} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.ownerUserId == request.auth.uid ||
        resource.data.linkedCustomerUserId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        resource.data.ownerUserId == request.auth.uid ||
        (
          (!('linkedCustomerUserId' in resource.data) || resource.data.linkedCustomerUserId == null) &&
          request.resource.data.linkedCustomerUserId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedCustomerUserId', 'updatedAt'])
        )
      );
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /credit_entries/{entryId} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.ownerUserId == request.auth.uid || 
        get(/databases/$(database)/documents/customers/$(resource.data.customerId)).data.linkedCustomerUserId == request.auth.uid
      );
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /payments/{paymentId} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.ownerUserId == request.auth.uid || 
        get(/databases/$(database)/documents/customers/$(resource.data.customerId)).data.linkedCustomerUserId == request.auth.uid
      );
      allow update: if false; 
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /transactions/{txnId} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.ownerUserId == request.auth.uid || 
        get(/databases/$(database)/documents/customers/$(resource.data.customerId)).data.linkedCustomerUserId == request.auth.uid
      );
      allow update: if false;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /customer_access_requests/{requestId} {
      allow create: if isAuthenticated() && request.resource.data.customerUserId == request.auth.uid && request.resource.data.status == 'pending';
      allow read: if isAuthenticated() && (
        resource.data.customerUserId == request.auth.uid ||
        resource.data.shopOwnerUserId == request.auth.uid ||
        get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerUserId == request.auth.uid
      );
      allow update: if isAuthenticated() && resource.data.shopOwnerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.customerUserId == request.auth.uid ||
        resource.data.shopOwnerUserId == request.auth.uid
      );
    }
    match /password_resets/{emailId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if request.resource.data.email is string && (request.auth == null || request.auth.token.email.lower() == request.resource.data.email.lower());
    }

    match /products/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /sales/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /sale_items/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /expenses/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /suppliers/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /purchases/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /purchase_items/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /cash_ups/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /wholesale_prices/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /shop_documents/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /reminders/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /incidents/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /food_safety_checks/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /municipality_contacts/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /shop_updates/{id} {
      allow create: if isAuthenticated() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
    }

    match /telemetry_events/{id} {
      allow create: if true;
      allow read, delete: if isAuthenticated() && request.auth.token.email == "franzic.bookings@gmail.com";
    }
  }
}
